      "config": {
        "googleMapsApiKey": "AIzaSyDummyKeyReplaceWithReal"
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1026"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKeyReplaceWithReal"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
