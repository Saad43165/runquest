{
  "expo": {
    "name": "RunQuest",
    "slug": "runquest",
    "version": "0.1.0",
    "orientation": "portrait",
    "backgroundColor": "#0b1026",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1026"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "package": "com.runquest.app"
    },
    "web": {
      "bundler": "webpack",
      "backgroundColor": "#0b1026"
    },
    
    "extra": {
      "serverUrl": "http://localhost:4000",
      "firebase": {
        "apiKey": "",
        "authDomain": "",
        "projectId": "",
        "storageBucket": "",
        "messagingSenderId": "",
        "appId": ""
      }
    }
  }
}
